# Copy to .env and fill in real values. Never commit .env.
# pydantic-settings validates these at boot — a missing key fails loudly at
# deploy, not silently at first request (backend-spec.md §6).

# ── Database (Supabase Postgres + pgvector) ─────────────────────────────────
# Render runtime connection — must use the read-only `app_readonly` role.
DATABASE_URL=postgresql://app_readonly:<password>@<host>:<port>/<database>

# Local-only, owner role — used exclusively by scripts/seed_db.py and
# scripts/generate_embeddings.py. Never set this in Render.
DATABASE_URL_OWNER=postgresql://postgres:<password>@<host>:<port>/<database>

# ── LLM (OpenRouter, via Vanna) ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-<your-key>
OPENROUTER_MODEL=<provider>/<flash-class-model-slug>
LLM_MAX_TOKENS_SQL=600
LLM_MAX_TOKENS_ANSWER=400

# ── Perimeter (CORS + rate limiting) ─────────────────────────────────────────
# Comma-separated if you need more than one, e.g. to also allow the local
# Vite dev server: https://<your-app>.vercel.app,http://localhost:5173
CORS_ORIGINS=https://<your-app>.vercel.app
RATE_LIMIT_QUERY=10/minute

# ── App ───────────────────────────────────────────────────────────────────
ENV=development

# ── Frontend (Vercel only — not read by the backend) ────────────────────────
VITE_API_BASE_URL=https://<your-api>.onrender.com
